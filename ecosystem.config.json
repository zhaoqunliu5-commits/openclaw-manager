{
  "apps": [
    {
      "name": "openclaw-manager-api",
      "script": "dist/index.js",
      "cwd": "./backend",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3002
      },
      "instances": 1,
      "autorestart": true,
      "max_restarts": 10,
      "restart_delay": 5000,
      "watch": false,
      "max_memory_restart": "512M",
      "error_file": "./logs/api-error.log",
      "out_file": "./logs/api-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "merge_logs": true
    }
  ]
}
